+/* =========================================================================
+ * GetForeignRelSize
+ * ========================================================================= */
+static void
+parquet_gsi_GetForeignRelSize(PlannerInfo *root, RelOptInfo *baserel,
+                              Oid foreigntableid)
+{
+    /* Probe the GSI and stash the file list for GetForeignPaths */
+    baserel->rows = baserel->tuples > 0 ? baserel->tuples : 1000.0;
+    baserel->fdw_private =
+        (void *) parquet_gsi_candidate_files_for_relation(root, baserel);
+}
+ 
+/* =========================================================================
+ * GetForeignPaths  — BUG C fixed: correct 10-arg PG16 signature
+ * ========================================================================= */
+static void
+parquet_gsi_GetForeignPaths(PlannerInfo *root, RelOptInfo *baserel,
+                            Oid foreigntableid)
+{
+    List       *candidate_files = (List *) baserel->fdw_private;
+    double      n_all, n_cand, pruned_rows;
+    Cost        startup_cost, total_cost;
+    ForeignPath *path;
+ 
+    /* Estimate pruned row count */
+    n_cand = (double) list_length(candidate_files);
+ 
+    /*
+     * We don't know the total file count here without another SPI call, so
+     * use a rough fraction: if we found N candidate files, assume the
+     * relation has proportionally fewer rows.
+     */
+    if (n_cand > 0 && baserel->tuples > 0)
+        pruned_rows = baserel->tuples / 10.0 * n_cand;  /* conservative */
+    else
+        pruned_rows = baserel->rows;
+ 
+    pruned_rows = Max(1.0, pruned_rows);
+ 
+    startup_cost = cpu_operator_cost * 10.0;
+    total_cost   = startup_cost + pruned_rows * cpu_tuple_cost
+                   + n_cand * seq_page_cost * 4.0;
+ 
+    /* BUG C fixed: PG16 create_foreignscan_path takes 10 args */
+    path = create_foreignscan_path(root,
+                                   baserel,
+                                   NULL,            /* default pathtarget */
+                                   pruned_rows,
+                                   startup_cost,
+                                   total_cost,
+                                   NIL,             /* no pathkeys */
+                                   baserel->lateral_relids,
+                                   NULL,            /* no extra plan */
+                                   list_make1(candidate_files));
+    add_path(baserel, &path->path);
+}
+ 
+/* =========================================================================
+ * GetForeignPlan
+ * ========================================================================= */
+static ForeignScan *
+parquet_gsi_GetForeignPlan(PlannerInfo *root,
+                           RelOptInfo  *baserel,
+                           Oid          foreigntableid,
+                           ForeignPath *best_path,
+                           List        *tlist,
+                           List        *scan_clauses,
+                           Plan        *outer_plan)
+{
+    /*
+     * Serialise the candidate file list (List of C-strings) into
+     * fdw_private as a List of String nodes so it survives plancache.
+     */
+    List     *file_strings = NIL;
+    List     *raw_files;
+    ListCell *lc;
+ 
+    if (best_path->fdw_private != NIL)
+        raw_files = (List *) linitial(best_path->fdw_private);
+    else
+        raw_files = NIL;
+ 
+    foreach(lc, raw_files)
+        file_strings = lappend(file_strings,
+                               makeString(pstrdup((char *) lfirst(lc))));
+ 
+    scan_clauses = extract_actual_clauses(scan_clauses, false);
+ 
+    return make_foreignscan(tlist,
+                            scan_clauses,
+                            baserel->relid,
+                            NIL,           /* no outer params */
+                            file_strings,  /* fdw_private = List of String */
+                            NIL,
+                            NIL,
+                            outer_plan);
+}
+ 
+/* =========================================================================
+ * BeginForeignScan
+ * ========================================================================= */
+static void
+parquet_gsi_BeginForeignScan(ForeignScanState *node, int eflags)
+{
+    ForeignScan            *plan   = (ForeignScan *) node->ss.ps.plan;
+    ParquetGsiFdwExecState *estate = palloc0(sizeof(ParquetGsiFdwExecState));
+    List                   *fdw_private = plan->fdw_private;
+    ListCell               *lc;
+    StringInfoData          query;
+    bool                    first  = true;
+ 
+    node->fdw_state = estate;
+ 
+    if (eflags & EXEC_FLAG_EXPLAIN_ONLY)
+        return;
+ 
+    /* Reconstruct candidate file list from List of String nodes */
+    foreach(lc, fdw_private)
+    {
+        Value *val = (Value *) lfirst(lc);
+        if (IsA(val, String))
+            estate->candidate_files =
+                lappend(estate->candidate_files, pstrdup(strVal(val)));
+    }
+ 
+    if (estate->candidate_files == NIL)
+        return;  /* nothing to scan */
+ 
+    /*
+     * Build: SELECT * FROM parquet.read_parquet(ARRAY['f1','f2',...])
+     * We use a SPI cursor (portal) so rows stream one fetch at a time.
+     */
+    initStringInfo(&query);
+    appendStringInfoString(&query,
+                           "SELECT * FROM parquet.read_parquet(ARRAY[");
+    foreach(lc, estate->candidate_files)
+    {
+        if (!first) appendStringInfoChar(&query, ',');
+        /* Single-quote and escape the path */
+        appendStringInfo(&query, "'%s'",
+                         ((char *) lfirst(lc)));
+        first = false;
+    }
+    appendStringInfoChar(&query, ']');
+    appendStringInfoChar(&query, ')');
+ 
+    if (SPI_connect() != SPI_OK_CONNECT)
+        elog(ERROR, "parquet_gsi_fdw: SPI_connect failed");
+ 
+    estate->portal = SPI_cursor_open_with_args(
+        NULL,           /* no portal name; anonymous */
+        query.data,
+        0, NULL, NULL, NULL,
+        true,           /* read-only */
+        0);
+ 
+    if (estate->portal == NULL)
+        elog(ERROR, "parquet_gsi_fdw: SPI_cursor_open failed for query: %s",
+             query.data);
+ 
+    estate->portal_open  = true;
+    estate->row_index    = 0;
+    estate->fetch_count  = 0;
+    estate->tuptable     = NULL;
+}
+ 
+/* =========================================================================
+ * IterateForeignScan  — BUG B fixed: actually returns rows
+ * ========================================================================= */
+#define GSI_FETCH_SIZE 100
+ 
+static TupleTableSlot *
+parquet_gsi_IterateForeignScan(ForeignScanState *node)
+{
+    ParquetGsiFdwExecState *estate = (ParquetGsiFdwExecState *) node->fdw_state;
+    TupleTableSlot         *slot   = node->ss.ss_ScanTupleSlot;
+ 
+    ExecClearTuple(slot);
+ 
+    /* No candidates or not initialised */
+    if (estate == NULL || !estate->portal_open)
+        return slot;
+ 
+    /* Fetch more rows if we've exhausted the current batch */
+    while (estate->row_index >= estate->fetch_count)
+    {
+        SPI_cursor_fetch(estate->portal, true /* forward */, GSI_FETCH_SIZE);
+ 
+        if (SPI_processed == 0)
+        {
+            /* End of result set */
+            SPI_cursor_close(estate->portal);
+            estate->portal_open = false;
+            SPI_finish();
+            return slot;  /* empty slot = end of scan */
+        }
+ 
+        estate->tuptable    = SPI_tuptable;
+        estate->fetch_count = (int64) SPI_processed;
+        estate->row_index   = 0;
+    }
+ 
+    /* Copy the current row into the scan slot */
+    {
+        HeapTuple   tuple   = estate->tuptable->vals[estate->row_index];
+        TupleDesc   tupdesc = estate->tuptable->tupdesc;
+ 
+        ExecStoreHeapTuple(heap_copytuple(tuple), slot, false);
+        (void) tupdesc; /* suppress warning if not used further */
+    }
+ 
+    estate->row_index++;
+    return slot;
+}
+ 
+/* =========================================================================
+ * ReScanForeignScan
+ * ========================================================================= */
+static void
+parquet_gsi_ReScanForeignScan(ForeignScanState *node)
+{
+    ParquetGsiFdwExecState *estate = (ParquetGsiFdwExecState *) node->fdw_state;
+ 
+    if (estate == NULL || !estate->portal_open)
+        return;
+ 
+    SPI_cursor_move(estate->portal, false /* backward */, FETCH_ALL);
+    estate->row_index   = 0;
+    estate->fetch_count = 0;
+    estate->tuptable    = NULL;
+}
+ 
+/* =========================================================================
+ * EndForeignScan
+ * ========================================================================= */
+static void
+parquet_gsi_EndForeignScan(ForeignScanState *node)
+{
+    ParquetGsiFdwExecState *estate = (ParquetGsiFdwExecState *) node->fdw_state;
+ 
+    if (estate == NULL)
+        return;
+ 
+    if (estate->portal_open)
+    {
+        SPI_cursor_close(estate->portal);
+        estate->portal_open = false;
+        SPI_finish();
+    }
+}
+ 
+/* =========================================================================
+ * candidate_files_for_relation  — BUG A fixed: returns actual file paths
+ *
+ * Runs parquet_gsi_candidate_files() via SPI, extracting numeric bounds
+ * from the baserel restriction info.  Returns a List of palloc'd char*.
+ * ========================================================================= */
+static List *
+parquet_gsi_candidate_files_for_relation(PlannerInfo *root, RelOptInfo *baserel)
+{
+    List       *files       = NIL;
+    ListCell   *lc;
+    char       *schema_name;
+ 
+    /* Walk restriction clauses looking for col = Const or col <op> Const */
+    const char *qual_column   = NULL;
+    double      lower_numeric = 0.0;
+    double      upper_numeric = 0.0;
+    bool        has_lower     = false;
+    bool        has_upper     = false;
+ 
+    schema_name = parquet_gsi_extension_schema();
+    if (schema_name == NULL)
+        return NIL;
+ 
+    foreach(lc, baserel->baserestrictinfo)
+    {
+        RestrictInfo *rinfo  = lfirst_node(RestrictInfo, lc);
+        OpExpr       *expr;
+        Var          *var;
+        Const        *cnst;
+        char         *colname;
+        char         *opname;
+ 
+        if (!IsA(rinfo->clause, OpExpr))
+            continue;
+        expr = (OpExpr *) rinfo->clause;
+        if (list_length(expr->args) != 2)
+            continue;
+ 
+        if (IsA(linitial(expr->args), Var) && IsA(lsecond(expr->args), Const))
+        {
+            var  = (Var *)   linitial(expr->args);
+            cnst = (Const *) lsecond(expr->args);
+        }
+        else if (IsA(lsecond(expr->args), Var) &&
+                 IsA(linitial(expr->args), Const))
+        {
+            var  = (Var *)   lsecond(expr->args);
+            cnst = (Const *) linitial(expr->args);
+        }
+        else
+            continue;
+ 
+        if (cnst->constisnull)
+            continue;
+        if (cnst->consttype != FLOAT8OID &&
+            cnst->consttype != INT4OID   &&
+            cnst->consttype != INT8OID)
+            continue;
+ 
+        /* Resolve column name */
+        {
+            RangeTblEntry *rte = planner_rt_fetch(var->varno, root);
+            colname = get_attname(rte->relid, var->varattno, true);
+        }
+        if (colname == NULL)
+            continue;
+ 
+        opname = get_opname(expr->opno);
+        if (opname == NULL)
+            continue;
+ 
+        {
+            double val;
+            switch (cnst->consttype)
+            {
+                case INT4OID:
+                    val = (double) DatumGetInt32(cnst->constvalue); break;
+                case INT8OID:
+                    val = (double) DatumGetInt64(cnst->constvalue); break;
+                case FLOAT8OID:
+                    val = DatumGetFloat8(cnst->constvalue);         break;
+                default:
+                    continue;
+            }
+ 
+            if (strcmp(opname, "=") == 0)
+            {
+                lower_numeric = upper_numeric = val;
+                has_lower = has_upper = true;
+            }
+            else if (strcmp(opname, ">") == 0 || strcmp(opname, ">=") == 0)
+            {
+                lower_numeric = val; has_lower = true;
+            }
+            else if (strcmp(opname, "<") == 0 || strcmp(opname, "<=") == 0)
+            {
+                upper_numeric = val; has_upper = true;
+            }
+            else
+                continue;
+ 
+            if (qual_column == NULL)
+                qual_column = pstrdup(colname);
+        }
+    }
+ 
+    /* No usable predicate found — return all indexed files as fallback */
+    if (qual_column == NULL)
+    {
+        StringInfoData sql;
+        initStringInfo(&sql);
+        appendStringInfo(&sql,
+                         "SELECT file_path FROM %s WHERE index_status = 'indexed'",
+                         quote_qualified_identifier(schema_name, "indexed_files"));
+ 
+        if (SPI_connect() != SPI_OK_CONNECT)
+            return NIL;
+        if (SPI_execute(sql.data, true, 0) == SPI_OK_SELECT)
+        {
+            uint64 i;
+            for (i = 0; i < SPI_processed; i++)
+            {
+                bool   isnull;
+                Datum  d = SPI_getbinval(SPI_tuptable->vals[i],
+                                         SPI_tuptable->tupdesc, 1, &isnull);
+                if (!isnull)
+                    files = lappend(files, pstrdup(TextDatumGetCString(d)));
+            }
+        }
+        SPI_finish();
+        return files;
+    }
+ 
+    /* Run parquet_gsi_candidate_files() for the extracted predicate bounds */
+    {
+        StringInfoData sql;
+        Oid            argtypes[3];
+        Datum          argvals[3];
+        char           argnulls[3];
+        int            ret;
+        uint64         i;
+ 
+        initStringInfo(&sql);
+        appendStringInfo(&sql,
+                         "SELECT * FROM %s($1, $2, $3, NULL, NULL)",
+                         quote_qualified_identifier(schema_name,
+                                                    "parquet_gsi_candidate_files"));
+ 
+        argtypes[0] = TEXTOID;
+        argvals[0]  = CStringGetTextDatum(qual_column);
+        argnulls[0] = ' ';
+ 
+        argtypes[1]  = FLOAT8OID;
+        argnulls[1]  = has_lower ? ' ' : 'n';
+        argvals[1]   = has_lower ? Float8GetDatum(lower_numeric) : (Datum) 0;
+ 
+        argtypes[2]  = FLOAT8OID;
+        argnulls[2]  = has_upper ? ' ' : 'n';
+        argvals[2]   = has_upper ? Float8GetDatum(upper_numeric) : (Datum) 0;
+ 
+        if (SPI_connect() != SPI_OK_CONNECT)
+            return NIL;
+ 
+        ret = SPI_execute_with_args(sql.data, 3, argtypes, argvals,
+                                    argnulls, true, 0);
+        if (ret == SPI_OK_SELECT)
+        {
+            for (i = 0; i < SPI_processed; i++)
+            {
+                bool   isnull;
+                Datum  d = SPI_getbinval(SPI_tuptable->vals[i],
+                                         SPI_tuptable->tupdesc, 1, &isnull);
+                if (!isnull)
+                    files = lappend(files,
+                                    MemoryContextStrdup(TopMemoryContext,
+                                                        TextDatumGetCString(d)));
+            }
+        }
+        SPI_finish();
+    }
+ 
+    return files;
+}
+void
+_PG_init(void)
+{
+	DefineCustomBoolVariable("parquet_gsi.enable_worker",
+						 "Enable the parquet_gsi background worker.",
+						 NULL,
+						 &parquet_gsi_enable_worker,
+						 true,
+						 PGC_POSTMASTER,
+						 0,
+						 NULL,
+						 NULL,
+						 NULL);
+
+	DefineCustomIntVariable("parquet_gsi.naptime",
+						"Seconds to sleep between parquet_gsi directory scans.",
+						NULL,
+						&parquet_gsi_naptime,
+						10,
+						1,
+						INT_MAX,
+						PGC_SIGHUP,
+						GUC_UNIT_S,
+						NULL,
+						NULL,
+						NULL);
+
+	DefineCustomStringVariable("parquet_gsi.database",
+						"Database used by the parquet_gsi static background worker.",
+						NULL,
+						&parquet_gsi_database,
+						"postgres",
+						PGC_POSTMASTER,
+						0,
+						NULL,
+						NULL,
+						NULL);
+
+	DefineCustomStringVariable("parquet_gsi.directory",
+						"Directory scanned by parquet_gsi for Parquet files.",
+						NULL,
+						&parquet_gsi_directory,
+						NULL,
+						PGC_SIGHUP,
+						0,
+						NULL,
+						NULL,
+						NULL);
+
+	MarkGUCPrefixReserved("parquet_gsi");
+
+	if (!process_shared_preload_libraries_in_progress)
+		return;
+
+	if (parquet_gsi_enable_worker)
+		parquet_gsi_register_worker();
+}
